# ══════════════════════════════════════════════════════════════

risk: LIVE RISK + SAFETY — Beacon Platform inspired {
  style.fill: "#fef2f2"
  style.stroke: "#ef4444"
  style.stroke-dash: 5
  style.border-radius: 10

  live: get_live_risk\n\nGREEN: all clear\nYELLOW: no new buys\nORANGE: sell only\nRED: auto kill switch {
    style.fill: "#fef2f2"
    style.stroke: "#ef4444"
  }

  monitors: Monitors\n\nDaily P&L limits\nATR stop distances\nVIX spike detection\nCash reserve % {
    style.fill: "#fef2f2"
    style.stroke: "#ef4444"
  }

  hook: Pre-Trade Hook + Kill Switch\n\nPositions, Concentration\nCash reserve, Drawdown 10% {
    style.fill: "#fef2f2"
    style.stroke: "#fca5a5"
  }

  sizer: Position Sizer\n\nKelly / ATR / Inverse-ATR {
    style.fill: "#f0fdf4"
    style.stroke: "#86efac"
  }

  monitors -> live: feeds
  live -> hook: RED triggers
}

