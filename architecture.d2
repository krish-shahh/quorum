# DATA + PERSISTENCE
# ══════════════════════════════════════════════════════════════

data: DATA + PERSISTENCE {
  style.fill: "#faf5ff"
  style.stroke: "#8b5cf6"
  style.stroke-dash: 5
  style.border-radius: 10

  market: Market Data (cached)\n\nyfinance: OHLCV, fundamentals\nReddit + StockTwits: sentiment\nWebSearch: real-time news\nKalshi API: events, orderbooks\n\n60s price / 15m sent / 1h news {
    style.fill: "#fffbeb"
    style.stroke: "#fcd34d"
  }

  db: SQLite Database\n\npositions, trades, wiki_pages\nticker_state, quant_scores\nkalshi_positions, arb_scans\nintraday_risk, signal_scores {
    style.fill: "#f5f3ff"
    style.stroke: "#c4b5fd"
  }

  persist: Persistence Layer\n\nWiki: analysis pages\nMemory: 5 session files\nAudit: MCP call JSONL\nBacktest: quant IC replay {
    style.fill: "#fff"
    style.stroke: "#e5e7eb"
  }

  math: Deterministic Math Layer\n\n9 sector scorers / Altman Z / FCF\nVaR, CVaR / Kelly, ATR sizing\nBrier, Log Score / PF, SQN\nALL math is deterministic Python {
    style.fill: "#f0fdf4"
    style.stroke: "#86efac"
  }

  market -> db: writes
  db -> persist: syncs
}

