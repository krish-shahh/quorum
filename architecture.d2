# ══════════════════════════════════════════════════════════════
# FLOW CONNECTIONS
# ══════════════════════════════════════════════════════════════

runtime -> preanalysis: Step 0-2.5 {style.stroke-dash: 3}
preanalysis -> layer1: spawn 4 agents {style.stroke: "#3b82f6"}
layer1 -> scoring: 4 scores (1-5) {style.stroke: "#10b981"}
scoring -> layer2: ambiguous → debate {style.stroke: "#8b5cf6"}
scoring -> execution: clear → execute {style.stroke: "#10b981"}
layer2 -> layer3: trader proposal {style.stroke: "#8b5cf6"}
layer3 -> execution: PM final signal {style.stroke: "#ef4444"}
data -> layer1: market data {style.stroke-dash: 3}
data -> predictions: Kalshi + news {style.stroke-dash: 3}
execution -> persistence: writes {style.stroke-dash: 3}
persistence -> layer3.reflection: outcome lessons {style.stroke-dash: 3}
