# quorum Configuration
# Copy to .env and edit: cp .env.example .env
# All values override defaults in quorum/default_config.py
# python-dotenv auto-loads this on import — no restart needed.
# No LLM API keys needed. All analysis runs through Claude Code subscription.

# ──────────────────────────────────────────────
# Execution Mode
# ──────────────────────────────────────────────
QUORUM_EXECUTION_MODE=paper          # "paper" or "schwab"
QUORUM_PAPER_BALANCE=5000            # starting paper cash

# ──────────────────────────────────────────────
# Position Sizing & Risk
# ──────────────────────────────────────────────
QUORUM_MAX_POSITION_PCT=0.25         # max % of portfolio per trade
QUORUM_MAX_SINGLE_TICKER_PCT=0.25    # max % in any single ticker
QUORUM_MAX_OPEN_POSITIONS=6          # max concurrent positions
QUORUM_MAX_DRAWDOWN_PCT=0.10         # kill switch threshold (10%)

# ──────────────────────────────────────────────
# Paper Broker Realism
# ──────────────────────────────────────────────
#QUORUM_PAPER_SLIPPAGE=false         # simulate spread + market impact
#QUORUM_PAPER_SPREAD_BPS=10          # spread in basis points

# ──────────────────────────────────────────────
# Schwab Live Trading (only if execution_mode=schwab)
# Steps: pip install ".[schwab]" → quorum auth-schwab → set mode above
# ──────────────────────────────────────────────
#SCHWAB_API_KEY=
#SCHWAB_API_SECRET=
#SCHWAB_ACCOUNT_HASH=

# ──────────────────────────────────────────────
# Scheduling
# ──────────────────────────────────────────────
#QUORUM_SCHEDULE_TIME=09:30          # daily cycle start (24h, Eastern)
#QUORUM_SCHEDULE_TIMEZONE=US/Eastern

# ──────────────────────────────────────────────
# Data (optional alternatives to yfinance)
# ──────────────────────────────────────────────
#ALPHA_VANTAGE_API_KEY=

# ──────────────────────────────────────────────
# Alerts (optional)
# ──────────────────────────────────────────────
#QUORUM_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/...
#QUORUM_ALERT_EMAIL_TO=you@example.com
#QUORUM_ALERT_SMTP_USER=you@gmail.com
#QUORUM_ALERT_SMTP_PASSWORD=app-password
