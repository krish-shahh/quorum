# TradingAgents — Configuration
# No LLM API keys needed. All analysis runs through Claude Code subscription.

# ── Paper Trading ──
#TRADINGAGENTS_PAPER_BALANCE=100000
#TRADINGAGENTS_MAX_POSITION_PCT=0.05
#TRADINGAGENTS_MAX_SINGLE_TICKER_PCT=0.25
#TRADINGAGENTS_MAX_OPEN_POSITIONS=6
#TRADINGAGENTS_MAX_DRAWDOWN_PCT=0.10

# ── Schwab (live trading, optional) ──
#SCHWAB_API_KEY=
#SCHWAB_API_SECRET=
#SCHWAB_ACCOUNT_HASH=

# ── Alpha Vantage (optional, alternative to yfinance) ──
#ALPHA_VANTAGE_API_KEY=

# ── Alerts (optional) ──
#TRADINGAGENTS_ALERT_SLACK_WEBHOOK=https://hooks.slack.com/services/...
