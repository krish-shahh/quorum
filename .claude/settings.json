{
  "env": {
    "TRADING_MODE": "paper",
    "MIN_CASH_RESERVE": "500",
    "MAX_DRAWDOWN_PCT": "0.10"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__tradingagents__execute_paper_trade",
        "hooks": [
          {
            "type": "command",
            "command": "python /Users/krish/Desktop/trader/.claude/hooks/pre_trade_validate.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__tradingagents__*",
        "hooks": [
          {
            "type": "command",
            "command": "python /Users/krish/Desktop/trader/.claude/hooks/post_tool_audit.py"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /Users/krish/Desktop/trader/.claude/hooks/post_tool_audit.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /Users/krish/Desktop/trader/.claude/hooks/session_start.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python /Users/krish/Desktop/trader/.claude/hooks/session_end.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__tradingagents__*",
      "WebSearch"
    ]
  },
  "disabledMcpjsonServers": [
    "code-review-graph",
    "shadcn",
    "claude.ai Google Calendar",
    "claude.ai Gmail",
    "claude.ai Google Drive"
  ]
}
