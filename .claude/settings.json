{
  "env": {
    "TRADING_MODE": "paper",
    "MIN_CASH_RESERVE": "500",
    "MAX_DRAWDOWN_PCT": "0.10"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "mcp__quorum__execute_paper_trade",
        "hooks": [
          {
            "type": "command",
            "command": "python $CLAUDE_PROJECT_DIR/.claude/hooks/pre_trade_validate.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "mcp__quorum__*",
        "hooks": [
          {
            "type": "command",
            "command": "python $CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_audit.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph update --skip-flows",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python $CLAUDE_PROJECT_DIR/.claude/hooks/post_tool_audit.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python $CLAUDE_PROJECT_DIR/.claude/hooks/session_start.py"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "code-review-graph status",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python $CLAUDE_PROJECT_DIR/.claude/hooks/session_end.py"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__quorum__*",
      "WebSearch"
    ]
  },
  "disabledMcpjsonServers": [
    "shadcn",
    "claude.ai Google Calendar",
    "claude.ai Gmail",
    "claude.ai Google Drive"
  ]
}